// Secrets.xcconfig.example
// SimFolio - Secret Configuration Template
//
// Copy this file to Secrets.xcconfig and replace the placeholder values with your actual keys.
// The Secrets.xcconfig file is excluded from git and should never be committed.
//
// Steps to set up:
// 1. Copy this file: cp Secrets.xcconfig.example Secrets.xcconfig
// 2. Replace YOUR_REVENUECAT_API_KEY_HERE with your actual RevenueCat API key
// 3. Build the project

// RevenueCat API Key
// Get this from: https://app.revenuecat.com/apps/<your-app>/api-keys
REVENUECAT_API_KEY = YOUR_REVENUECAT_API_KEY_HERE
